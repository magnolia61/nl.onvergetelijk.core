      wachthond($extdebug,2, "########################################################################");
      wachthond($extdebug,1, "### CORE 5.2 d BEPAAL OF ER EEN FIETS MOET WORDEN GEHUURD", "[$displayname $ditevent_part_functie $ditevent_event_kampkort]");
      wachthond($extdebug,2, "########################################################################");

      $params_lineitem_fiets = [
        'checkPermissions' => FALSE,
