    $kampgeldregeling       = NULL;

    $status_positief        = array(1,2,5,6,15,16); //  BETEKENT DEELNAME = YES
    $status_negatief        = array(4,11,17,26);    //  BETEKENT DEELNAME = NO (GECANCELED, AFGEKEURD OF OVERGEDRAGEN)
