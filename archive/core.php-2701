    // STATUSSEN WORDEN VERDEROP UIT CACHE GEHAALD

    $status_wachtlijst      = array(7);             //  WACHT OP PLEK               Waiting
    $status_criteria        = array(8);             //  WACHT OP GOEDKEURING (EERST CONTROLE) Criteria
    $status_bevestig        = array(9,10);          //  WACHT OP BEVESTIGING (VAN DE OUDERS)  Pending
    $status_negative        = array(4,26);          //  GEANNULEERDE              Negative

    $eventtypesdeel         = array(11,12,13,14,21,22,23,24,33);//  EVENT_TYPE_ID'S KAMPEN DITJAAR (- TEST_DEEL)
    $eventtypesdeelkkjk     = array(11,12,13,14,21,22,23,24);   //  EVENT_TYPE_ID'S KAMPEN DITJAAR (- TEST_DEEL)   
    $eventtypesdeeltop      = array(33);                        //  EVENT_TYPE_ID'S KAMPEN DITJAAR (- TEST_DEEL)
