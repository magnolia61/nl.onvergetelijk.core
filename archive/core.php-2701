    wachthond($extdebug,2, "########################################################################");
    wachthond($extdebug,1, "### CORE 5.5 SAVE CORRECT PARTICIPANT ROLE ID", "[$displayname $ditevent_part_functie $ditevent_event_kampkort]");
    wachthond($extdebug,2, "########################################################################");

