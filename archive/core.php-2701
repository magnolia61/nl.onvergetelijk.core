    wachthond($extdebug,4, 'grensrefnoggoed3',          $grensrefnoggoed3);

//  $today_fiscalyear_check = CRM_Utils_Type::validate($today_fiscalyear_start, "Date");
//  wachthond($extdebug,1, "today_datetimenext_check voor $today_fiscalyear_start", $today_fiscalyear_check);

    wachthond($extdebug,4, "########################################################################");
    wachthond($extdebug,4, "### CORE 0.2 VIND GECONFIGUREERDE DEELNAME STATUSSEN (POS/NEG)");
    wachthond($extdebug,4, "########################################################################");

//  if (!Civi::cache()->get('cache_status_positive')) {
        find_partstatus();
//  }

    ################################################################################################
    # RETREIVE TODAY FISCAL YEAR START VALUE FROM CACHE
    ################################################################################################
    $status_positive    = Civi::cache()->get('cache_status_positive');
    $status_pending     = Civi::cache()->get('cache_status_pending');
    $status_waiting     = Civi::cache()->get('cache_status_waiting');
    $status_negative    = Civi::cache()->get('cache_status_negative');

    wachthond($extdebug,4, 'statusids_positive',  $status_positive);
    wachthond($extdebug,4, 'statusids_pending',   $status_pending);
    wachthond($extdebug,4, 'statusids_waiting',   $status_waiting);
    wachthond($extdebug,4, 'statusids_negative',  $status_negative);

    wachthond($extdebug,4, 'statusids_positief',  $status_positief);
    wachthond($extdebug,4, 'statusids_negatief',  $status_negatief);
    wachthond($extdebug,4, 'statusids_misschien', $status_misschien);  

    wachthond($extdebug,4, "########################################################################");
    wachthond($extdebug,4, "### CORE 0.3 VIND ALLE EVENT LEIDING & DEELNEMERS VOOR DIT JAAR");
    wachthond($extdebug,4, "########################################################################");

//  if (!Civi::cache()->get('cache_kampids_deel')) {
        find_eventids();
//    }

    ##########################################################################################
    # RETREIVE EVENT ID'S FROM CACHE
    ##########################################################################################
    $kampids_deel       = Civi::cache()->get('cache_kampids_deel');
    $kampids_leid       = Civi::cache()->get('cache_kampids_leid');
    $kampids_meet       = Civi::cache()->get('cache_kampids_meet');

    $kampids_deel_top   = Civi::cache()->get('cache_kampids_deel_top');
    $kampids_deel_leid  = Civi::cache()->get('cache_kampids_deel_leid');

    $kampids_deel_all   = Civi::cache()->get('cache_kampids_deel_all');
    $kampids_leid_all   = Civi::cache()->get('cache_kampids_leid_all');
    $kampids_all        = Civi::cache()->get('cache_kampids_all');

    $kampids_test_deel  = Civi::cache()->get('cache_kampids_test_deel');
    $kampids_test_leid  = Civi::cache()->get('cache_kampids_test_leid');
    $kampids_test_all   = Civi::cache()->get('cache_kampids_test_all');        

    wachthond($extdebug,4, 'kampids_deel',      $kampids_deel);
    wachthond($extdebug,4, 'kampids_leid',      $kampids_leid);   
    wachthond($extdebug,4, 'kampids_meet',      $kampids_meet);   

    wachthond($extdebug,4, 'kampids_deel_top',  $kampids_deel_top);
    wachthond($extdebug,4, 'kampids_deel_leid', $kampids_deel_leid);

