        if ($email_othr_email != $part_notificatie_othr) {
          $email_email_othr_delete = civicrm_api4('Email', 'delete', [
            'where' => [
              ['id', '=', $email_othr_id],
            ],
          ]);

            wachthond($extdebug,2, 'email_othr verwijderd', "$email_othr_email ($email_othr_id)");
          $email_othr_removed = 1;
        }
      }
      
      ### EMAIL UPDATE
      if ($email_othr_email != $new_email_othr_email AND !empty($new_email_othr_email)) {
        $params_email_othr_update = [
          'checkPermissions' => FALSE,
          'debug' => $apidebug,
          'where' => [
            ['id',          '=', $email_othr_id],
            ['contact_id',      '=', $contact_id],
          ],
          'values' => [
            'email'          =>  $new_email_othr_email,
            'location_type_id:name'  =>  "Other",
            'is_primary'       =>  FALSE,
          ],
        ];
            wachthond($extdebug,7, 'params_email_othr_update',        $params_email_othr_update);
        if ($extwrite == 1 AND !in_array($privacy_voorkeuren, array("33","44"))) {
            $result_email_othr_update = civicrm_api4('Email', 'update', $params_email_othr_update);
          }
          wachthond($extdebug,9, 'result_email_othr_update',  $result_email_othr_update);
        wachthond($extdebug,2, 'email_othr geupdated',    $new_email_othr_email);
      }
    }

