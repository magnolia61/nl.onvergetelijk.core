    $intakestatusfot = "";
    wachthond($extdebug,3, '0 intakestatusfot', $intakestatusfot);

    if (empty($contact_foto)) {
      
      $intakestatusfot  = "0";

      if ($geslacht == 'jongen') {
        $contact_foto = "https://www.onvergetelijk.nl/sites/default/files/ozkimages/placeholder_boy.svg";
      }
      if ($geslacht == 'meisje') {
        $contact_foto = "https://www.onvergetelijk.nl/sites/default/files/ozkimages/placeholder_girl.svg";
      }
      if ($geslacht != 'jongen' AND $geslacht != 'meisje') {
        $contact_foto = "https://www.onvergetelijk.nl/sites/default/files/ozkimages/placeholder.svg";
      }

      if ($contact_foto) { $params_contact['values']['image_URL'] = $contact_foto;          }
    }

    if (str_contains($contact_foto, 'ozkimages')  AND  str_contains($contact_foto, 'placeholder'))  {
      $intakestatusfot  = "0";
    } 
    if (str_contains($contact_foto, 'imagefile')  AND  str_contains($contact_foto, 'placeholder'))  {
      $intakestatusfot  = "0";
    } 
    if (str_contains($contact_foto, 'uploads')    AND !str_contains($contact_foto, 'placeholder'))  {
      $intakestatusfot  = "1";
    } 
    if (str_contains($contact_foto, 'imagefile')  AND !str_contains($contact_foto, 'placeholder'))  {
      $intakestatusfot  = "1";
    } 
    if (str_contains($contact_foto, 'profielfotos') AND  str_contains($contact_foto, 'instagram'))  {
      $intakestatusfot  = "1";
    } 
    if (str_contains($contact_foto, 'profielfotos') AND  str_contains($contact_foto, 'square'))     {
      $intakestatusfot  = "2";
