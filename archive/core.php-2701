    if ((empty($email_othr_id) AND !empty($new_email_othr_email)) OR $email_othr_removed == 1) {
      $params_email_othr_create = [
        'checkPermissions' => FALSE,
        'debug' => $apidebug,         
        'values' => [
          'contact_id'      => $contact_id,
          'email'         => $new_email_othr_email,
          'location_type_id:name' => "Other",
        ],
      ];
          wachthond($extdebug,7, 'params_email_othr_create',        $params_email_othr_create);
