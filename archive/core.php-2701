              'CONT_KAMPGELD.kampkort'    => $eventkamp_kampkort, // IS DROPDOWN

              'CONT_KAMPGELD.kamptype_naam' => $eventkamp_kamptype_naam,
              'CONT_KAMPGELD.kamptype_id'   => $eventkamp_kamptype_id,
              'CONT_KAMPGELD.kampweek_nr'   => $eventkamp_event_weeknr,   
              'CONT_KAMPGELD.datum_kamp'    => $eventkamp_event_start,

              'CONT_KAMPGELD.bedrag'      => $saldo_bedrag,
              'CONT_KAMPGELD.betaald'     => $saldo_paid,
              'CONT_KAMPGELD.saldo'       => $saldo_balance,

              'CONT_KAMPGELD.regeling'    => $new_kampgeldregeling,
              'CONT_KAMPGELD.kenmerk'     => $contribution_kenmerk,
            ],
          ];
        }

/*
        wachthond($extdebug,7, 'params_contrib',            $params_contrib);
        if ($contrib_id AND $eventkamp_event_start AND $ditevent_kampjaar != 2015) {
