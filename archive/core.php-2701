    $curcv_leid_array       = [];
    $curcv_deel_array_nr    = 0;
    $curcv_leid_array_nr    = 0;
    $evtcv_deel_array       = [];
    $evtcv_deel_top_array   = [];
    $evtcv_leid_array       = [];
