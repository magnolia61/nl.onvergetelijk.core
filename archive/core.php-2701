    $eventjaar_pos_deel_event_type_id   = $array_allpart_eventjaar['result_allpart_pos_deel_event_type_id'];
    $eventjaar_pos_leid_event_type_id   = $array_allpart_eventjaar['result_allpart_pos_leid_event_type_id'];

